// IronClaw Reborn ProductAdapter v2 WIT contract (issue #3285).
//
// This WIT file documents the constrained capability boundary the v2 host
// runtime exposes to ProductAdapter WASM components. wasmtime component
// bindgen is wired in `ironclaw_wasm_product_adapters`; production protocol
// adapters can target this world as installable WASM components.
//
// Host-imposed invariants (enforced regardless of the component-model glue):
//
// - The host MUST verify webhook/protocol authentication before invoking
//   `parse-inbound`. Components cannot mint a `verified` auth-evidence value
//   and the host's seal mechanism is unreachable from WASM.
// - `parse-inbound` returns the adapter's parsed DTO only. The host stamps
//   trusted adapter/install/received/auth context after parsing and before
//   entering product workflow code.
// - Ignored-but-authenticated events are represented in the parsed DTO as the
//   contract's no-op payload variant. They are not represented by an absent
//   parse result.
// - `http-egress` is the only network capability this WIT world reserves for
//   components. This PR slice is intentionally parse/render-only: the host
//   import fails closed until a follow-up injects the production
//   host-runtime egress service. Components still declare a fixed list of
//   egress TARGETS via `declared-egress-targets`, where each target is the
//   paired `(host, optional credential_handle)` shape the host's
//   `EgressPolicy` enforces for rendered requests.
// - Once production component egress is wired, the host will reject requests
//   to undeclared pairs — including the cross-pair leak case (a credential
//   declared for a different host) and the unauthenticated-bypass case (a
//   bare request to a host declared only with credentialed pairs). Credential
//   handles are opaque ids; the host resolves and applies the underlying
//   secret material at request time.
// - Response bodies returned to WASM via future `http-egress` wiring must be
//   scanned for leak-pattern matches by the host before the WASM instance can
//   observe them. Raw response headers remain host-only and are not exposed
//   here.
// - `log`, `now-millis`, and v1-style minimal WASI p2 are the only
//   general-purpose host imports. Minimal WASI keeps wasm32-wasip2 guest
//   compatibility and permits clock/random, but the host provides no env,
//   args, stdio, preopened directories, or network access. HTTP egress still
//   flows only through `http-egress`.
//
// TEMPORARY: JSON-string payload shim
// ===================================
// The `parsed-inbound`, `auth-evidence`, `outbound-envelope`,
// `outbound-render`, and `adapter-manifest.capabilities-json` records
// carry their payloads as `string` (JSON-encoded) instead of typed
// component-model records. This is a deliberate temporary shim so the
// host-side Rust DTOs in `ironclaw_product_adapters` can evolve without
// rev'ing the WIT signature on every field addition. The host still
// type-checks every JSON crossing back into Rust via serde, so it
// cannot fabricate verified evidence or smuggle host-only fields —
// the seal mechanism is enforced on the Rust side.
//
// Follow-up: replace these `*-json: string` fields with typed records
// once the DTOs in `ironclaw_product_adapters` stabilize. The boundary
// test `wasm_product_adapter_wit_pins_json_shim_shape` in
// `crates/ironclaw_architecture/tests/reborn_dependency_boundaries.rs`
// pins the current shape so future changes are deliberate — removing
// any of the JSON-shim fields without also updating that test (and
// landing the corresponding typed record) will fail boundary checks.

package near:product-adapter@0.1.0;

interface product-adapter-host {
    enum log-level { trace, debug, info, warn, error }

    log: func(level: log-level, message: string);
    /// Wall-clock UTC milliseconds since the Unix epoch. NOT monotonic:
    /// the host returns whatever the system clock reports, which may step
    /// backwards on NTP correction or operator clock changes. Components
    /// must use this value for logging/timestamping only — not for TTL or
    /// idempotency comparisons.
    now-millis: func() -> u64;

    record egress-headers {
        entries: list<tuple<string, string>>,
    }

    record egress-request {
        // Index into the manifest's `declared-egress-targets`. The host
        // reads BOTH the target host AND the (optional) credential
        // handle from this single pair — components cannot mix a
        // credential from one declared pair with the host of another.
        // This is the WIT-side of the `EgressPolicy::check` pair
        // contract: an attempt to send `slack_token` against
        // `api.telegram.org` is impossible to express because there's
        // no separate handle index to mismatch the host with.
        egress-target-index: u32,
        method: string,
        path: string,
        headers: egress-headers,
        body: list<u8>,
    }

    record egress-response {
        status: u16,
        body: list<u8>,
    }

    enum egress-error-kind {
        undeclared-host,
        unknown-credential-handle,
        unauthorized-credential-handle,
        policy-denied,
        timeout,
        leak-detected,
        network,
    }

    record egress-error {
        kind: egress-error-kind,
        message: string,
    }

    http-egress: func(request: egress-request) -> result<egress-response, egress-error>;
}

interface product-adapter {
    record parsed-inbound {
        parsed-json: string,
    }

    record auth-evidence {
        // Host-serialized sealed auth evidence. Components treat this as
        // opaque input; component-supplied JSON cannot impersonate a
        // `verified` claim because the host-side Deserialize impl rejects
        // unsealed verified variants.
        evidence-json: string,
    }

    record outbound-envelope {
        outbound-json: string,
    }

    record outbound-render {
        // Component-side render result. The host applies it via
        // `http-egress` after re-validating against declared hosts.
        egress-request-json: string,
    }

    enum auth-requirement-kind {
        request-signature,
        shared-secret-header,
        session-cookie,
        bearer-token,
    }

    record auth-requirement {
        kind: auth-requirement-kind,
        header-name: option<string>,
        timestamp-header-name: option<string>,
        cookie-name: option<string>,
    }

    /// A single declared `(host, optional credential_handle)` pair. The
    /// host's `EgressPolicy` authorizes requests against the EXACT pair
    /// — an adapter that wants to be reachable both with and without a
    /// credential for the same host must declare two targets (one with
    /// `credential-handle = none`, one with `credential-handle = some`).
    /// Mirrors `ironclaw_product_adapters::DeclaredEgressTarget` on the
    /// Rust side.
    record declared-egress-target {
        host: string,
        // Opaque id of the credential the host applies for this target.
        // `none` declares an unauthenticated egress target — components
        // sending bare requests to a credential-only host are rejected
        // by the host's `EgressPolicy::check`.
        credential-handle: option<string>,
    }

    record adapter-manifest {
        adapter-id: string,
        installation-id: string,
        capabilities-json: string,
        // Paired egress declarations. Replaces the prior independent
        // `declared-egress-hosts` + `declared-credential-handles` lists,
        // which could not express "Slack token only for Slack" and
        // would have forced the host glue to either reintroduce the
        // cross-pair leak the Rust policy closes, or invent pair
        // metadata the manifest did not carry.
        declared-egress-targets: list<declared-egress-target>,
        declared-auth-requirements: list<auth-requirement>,
    }

    /// Return the component's manifest. Read at instantiation time and
    /// snapshotted by the host.
    manifest: func() -> adapter-manifest;

    /// Parse a verified protocol payload into a ParsedProductInbound JSON DTO.
    /// Authenticated ambient group messages and other ignored events are
    /// represented by the DTO's no-op payload variant. Returns `error` only
    /// when the payload is malformed beyond what the adapter chooses to ignore.
    parse-inbound: func(
        raw-payload: list<u8>,
        evidence: auth-evidence,
    ) -> result<parsed-inbound, string>;

    /// Render an outbound envelope into an HTTP egress request. In this
    /// parse/render-only slice, the Rust host returns the validated typed
    /// request to trusted host code; production `http-egress` execution from
    /// inside WASM is deferred to follow-up host-runtime wiring. The host
    /// re-validates the egress request against the manifest before any send.
    render-outbound: func(
        envelope: outbound-envelope,
    ) -> result<outbound-render, string>;
}

world product-adapter-component {
    import product-adapter-host;
    export product-adapter;
}
